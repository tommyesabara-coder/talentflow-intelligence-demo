# Copy this file to .env and put your real key there.
# Never commit or share the real .env file.
OPENAI_API_KEY=
OPENAI_RESUME_MODEL=gpt-5.5
OPENAI_RESUME_FALLBACK_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
GEMINI_RESUME_MODEL=gemini-2.5-flash

# Hybrid parser: cepat untuk CV confidence tinggi, AI hanya untuk field yang ragu
HYBRID_FAST_PARSER=true
HYBRID_CONFIDENCE_THRESHOLD=0.78
HYBRID_FIELD_CONFIDENCE_THRESHOLD=0.64

# Multi-engine AI routing
# random = pilih engine aktif secara acak, lalu fallback jika gagal
# ordered = ikuti urutan AI_ENGINE_PROVIDERS
AI_ENGINE_STRATEGY=random
AI_ENGINE_PROVIDERS=gemini,openai,together

TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.ai/v1
TOGETHER_MODEL=openai/gpt-oss-20b

# Local AI, tanpa API berbayar
LOCAL_ONLY_PARSER=true
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_RESUME_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=2048
